# ============================================
# Trafficker Hub Pro - Variables de entorno
# Copia este archivo como ".env" y completa lo que tengas.
# Todo lo que falte funciona en modo demo (datos/plantillas locales).
# ============================================

PORT=5000

# ============================================
# IA — el sistema usa la PRIMERA que encuentre configurada, en este orden.
# Todas las opciones marcadas GRATIS no requieren tarjeta de crédito.
# ============================================

# 1) Google Gemini — GRATIS (recomendada)
#    Crea tu key en 2 minutos: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# 2) Groq (Llama 3.3 70B, muy rápida) — GRATIS
#    Key en: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# 3) OpenRouter (acceso a modelos :free) — GRATIS
#    Key en: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# 4) OpenAI — de pago (opcional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# 5) Ollama — GRATIS y 100% local (sin internet)
#    Instala https://ollama.com y ejecuta: ollama pull llama3.2
#    Luego descomenta:
# OLLAMA_MODEL=llama3.2
# OLLAMA_URL=http://localhost:11434

# 6) Pollinations.ai — GRATIS sin registro. Se usa como último recurso
#    automáticamente (suele estar saturado). Para desactivarlo:
# DESACTIVAR_POLLINATIONS=true

# ============================================
# Plataformas publicitarias (modo demo si están vacías)
# ============================================

# --- Meta (Facebook/Instagram) Ads - Graph API ---
# Token en https://developers.facebook.com/tools/explorer (permiso: ads_read)
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_XXXXXXXXXX

# --- Google Ads API ---
# Guía: https://developers.google.com/google-ads/api/docs/get-started/introduction
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# --- Prospector de clientes (escaneo de negocios por zona) ---
# Por defecto usa OpenStreetMap (Nominatim + Overpass): GRATIS y sin key.
# Para usar Google Maps (Places API) en su lugar — trae además rating y nº de
# reseñas y suele tener más negocios:
#   1. Entra a https://console.cloud.google.com/ y crea un proyecto.
#   2. Activa "Places API (New)" y habilita facturación (Google da USD 200/mes
#      gratis, suficiente para miles de búsquedas, pero pide tarjeta).
#   3. Crea una API key en "Credenciales" y pégala aquí abajo.
# Si se deja vacío, el prospector usa OpenStreetMap automáticamente.
GOOGLE_MAPS_API_KEY=

# --- Base de datos ---
# SQLite por defecto (archivo local, cero configuración).
DB_PATH=./data/trafficker.db
